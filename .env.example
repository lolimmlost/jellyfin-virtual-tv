# Required — Jellyfin connection
JELLYFIN_URL=http://jellyfin:8096
JELLYFIN_API_KEY=your-api-key-here

# Required for production — external URL clients use to reach the streams
# (must be reachable by Jellyfin and any IPTV client devices on your LAN)
BASE_URL=http://your-host:3336

# Optional
PORT=3000
DB_PATH=./data/virtual-tv.db
NODE_ENV=production

# Optional — IANA timezone that controls schedule day boundaries.
# Defaults to America/Los_Angeles. Set to your local zone so daily blocks
# (e.g. midnight resets) align with your wall clock.
SCHEDULE_TZ=America/Los_Angeles
